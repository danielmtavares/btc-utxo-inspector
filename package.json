{
  "name": "btc-utxo-inspector",
  "version": "0.0.1",
  "description": "A CLI for inspecting Bitcoin addresses, summarizing UTXOs and balances, and analyzing transaction details using public blockchain APIs.",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "dev": "node --import tsx src/cli.ts",
    "start": "node --import tsx src/cli.ts",
    "build": "tsup src/cli.ts src/index.ts --format esm --out-dir dist --clean --sourcemap",
    "test": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielmtavares/btc-utxo-inspector.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/danielmtavares/btc-utxo-inspector/issues"
  },
  "homepage": "https://github.com/danielmtavares/btc-utxo-inspector#readme",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
