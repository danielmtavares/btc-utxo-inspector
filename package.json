{
  "name": "btc-utxo-inspector",
  "version": "0.0.1",
  "description": "A CLI for inspecting Bitcoin addresses, summarizing UTXOs and balances, and analyzing transaction details using public blockchain APIs.",
  "keywords": [
    "bitcoin",
    "blockstream",
    "cli",
    "typescript",
    "utxo"
  ],
  "homepage": "https://github.com/danielmtavares/btc-utxo-inspector#readme",
  "bugs": {
    "url": "https://github.com/danielmtavares/btc-utxo-inspector/issues"
  },
  "license": "ISC",
  "author": "Daniel Tavares",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielmtavares/btc-utxo-inspector.git"
  },
  "bin": {
    "btc-utxo-inspector": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "audit:prod": "pnpm audit --prod --audit-level high",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test -- --run && pnpm build",
    "dev": "node --import tsx src/cli.ts",
    "build": "tsup --config tsup.config.ts",
    "format": "oxfmt \"*.{json,js,ts}\" \"src/**/*.{ts,json}\" \"test/**/*.{ts,json}\" \".github/**/*.{md,yml,yaml}\"",
    "format:check": "oxfmt --check \"*.{json,js,ts}\" \"src/**/*.{ts,json}\" \"test/**/*.{ts,json}\" \".github/**/*.{md,yml,yaml}\"",
    "lint": "oxlint . --import-plugin --promise-plugin --vitest-plugin --deny-warnings",
    "lint:fix": "oxlint . --import-plugin --promise-plugin --vitest-plugin --fix",
    "prepare": "git config core.hooksPath .githooks",
    "prepack": "pnpm build",
    "start": "node dist/cli.js",
    "test": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "packageManager": "pnpm@11.1.3"
}
